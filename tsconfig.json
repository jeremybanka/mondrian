{
	"compilerOptions": {
		"allowImportingTsExtensions": true,
		"allowSyntheticDefaultImports": true,
		"declaration": true,
		"erasableSyntaxOnly": true,
		"exactOptionalPropertyTypes": true,
		"lib": ["ES2024"],
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"noEmit": true,
		"noUncheckedIndexedAccess": true,
		"rootDir": ".",
		"skipLibCheck": true,
		"strict": true,
		"target": "ES2024",
		"types": []
	},
	"include": ["**/*.ts", "*.d.ts"]
}
