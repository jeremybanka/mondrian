{
	"name": "mondrian-workspace",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "vp run --filter mondrian.pdf --fail-if-no-match build",
		"change": "changeset",
		"check": "vp check --no-fmt .pnpmfile.mjs vite.config.ts packages/mondrian && tsc --noEmit",
		"fmt": "dprint fmt",
		"fmt:check": "dprint check --excludes \"packages/fitter-happier/**\"",
		"lint": "vp lint",
		"release": "pnpm build && changeset publish",
		"staged": "vp staged",
		"test": "vp run --filter mondrian.pdf --fail-if-no-match test"
	},
	"devDependencies": {
		"@changesets/cli": "2.31.0",
		"@changesets/config": "3.1.4",
		"@dprint/json": "0.23.0",
		"@dprint/markdown": "0.22.1",
		"@dprint/oxc": "0.29.0",
		"@dprint/toml": "0.7.0",
		"dprint": "0.55.1",
		"dprint-plugin-malva": "0.16.0",
		"dprint-plugin-markup": "0.27.3",
		"dprint-plugin-yaml": "0.6.0",
		"typescript": "7.0.2",
		"vite-plus": "0.2.4"
	},
	"engines": {
		"node": "26.5.0",
		"pnpm": "11.10.0"
	},
	"packageManager": "pnpm@11.10.0"
}
